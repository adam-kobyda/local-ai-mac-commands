#!/usr/bin/env bash
set -euo pipefail

DOWNLOADS_DIR="$HOME/Downloads"

latest=$(find "$DOWNLOADS_DIR" -maxdepth 1 -not -name ".*" -type f -print0 \
  | xargs -0 ls -t 2>/dev/null \
  | head -n 1) || true

if [[ -z "$latest" ]]; then
  echo "No files found in $DOWNLOADS_DIR" >&2
  exit 1
fi

echo "$latest"
